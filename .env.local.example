# Copy this file to .env.local and add your keys

# Optional — enables high-quality neural TTS (free tier: 10k chars/month)
# Get one at https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Optional — override the default voice (default: "Chris" news anchor)
# Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=
